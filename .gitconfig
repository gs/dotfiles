[color]
  diff = auto
  status = auto
  interactive = auto
  ui = auto
  pager = true

[merge]
  summary=false
  tool = opendiff

[branch]
  autosetupmerge = true

[apply]

[alias]
  st = status
  ci = commit
  co = checkout
  di = diff
  dc = diff --cached
  amend = commit --amend
  aa = add --all
  ff = merge --ff-only
  pullff = pull --ff-only
  noff = merge --no-ff
  div = divergence
  gn = goodness
  gnc = goodness --cached
  fa = fetch --all
  pom = push origin master
  b = branch
  ds = diff --stat=160,120
  dh1 = diff HEAD~1
  head = !git l -1
  h = !git head
  hp = !show_git_head
#    r = !git l -30
  r = log --all --decorate --oneline --graph
  ra = !git r --all
  l = log --all --decorate --oneline --graph
  la = !git l --all
  pr = !hub pull-request
  usr = !git-usr

[user]
#  name = 
#  email = 
[diff]
  tool = opendiff
[push]
  default = tracking
[web]
  browser = open
[core]
  editor = /opt/homebrew/bin/nvim
